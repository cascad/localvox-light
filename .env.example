# Скопируйте в `.env`. Подхватывается через dotenvy при старте; аргументы CLI важнее переменных.
# Разработка: обычно корень репозитория (cwd при `cargo run`).
# Портативная установка (install-release): `.env` рядом с `localvox-light(.exe)` читается из папки exe (даже при другом cwd) и перекрывает одноимённые переменные из системы/сессии; `vosk-lib/` рядом с exe добавляется в PATH / LD_LIBRARY_PATH.
#
# Префикс LOCALVOX_LIGHT_* чтобы не пересекаться с сервером / client-reliable.

# ── Модель Vosk (дефолт = каталог из setup-vosk: models/vosk-model-ru-0.42) ──
# Первичная установка: ./scripts/setup-vosk.sh … или scripts\setup-vosk.ps1 → models/ и vosk-lib/
# Windows: лучше без кавычек и со слэшами / (в кавычках F:\vosk\... — \v может стать escape в .env)
# LOCALVOX_LIGHT_MODEL=models/vosk-model-ru-0.42

# ── Устройства (перекрывают localvox-light-config.json, см. LOCALVOX_LIGHT_CONFIG) ──
# LOCALVOX_LIGHT_MIC=default
# LOCALVOX_LIGHT_LOOPBACK_DEVICE=default-output
# LOCALVOX_LIGHT_CONFIG=./localvox-light-config.json

# ── Рабочий каталог (wav + transcript.jsonl в корне; без вложенных session_*) ──
LOCALVOX_LIGHT_AUDIO_DIR=localvox-audio

# Каталог для экспорта по [e] в TUI: transcript_dump_*.jsonl (строки по времени + seg, не порядок ASR). Пустое — экспорт отключён.
LOCALVOX_LIGHT_TRANSCRIPT_DUMP_DIR=./transcript-dumps

# ── Сегментация / VAD / шум ──
LOCALVOX_LIGHT_MAX_CHUNK_SEC=10
LOCALVOX_LIGHT_MIN_CHUNK_SEC=1.5
LOCALVOX_LIGHT_VAD_SILENCE_SEC=0.8
LOCALVOX_LIGHT_NOISE_GATE=0.15

# ── ASR ──
LOCALVOX_LIGHT_ASR_WORKERS=2

# ── Режимы (1 / true / yes / on — включить; иначе выкл.) ──
# В интерактивном терминале TUI включается сам, если LOCALVOX_LIGHT_TUI не задан в окружении.
# LOCALVOX_LIGHT_TUI=1
# Только логи в stderr, без TUI (перекрывает авто-TUI): LOCALVOX_LIGHT_NO_TUI=1 или флаг --no-tui
# LOCALVOX_LIGHT_NO_TUI=1
# Подробные строки этапов в панели TUI (segment / gate / asr / load …); без этого — только ошибки в панели.
# LOCALVOX_LIGHT_VERBOSE=1
# Подробный stderr (tracing); не путать с VERBOSE.
# LOCALVOX_LIGHT_DEBUG=1
# LOCALVOX_LIGHT_LOOPBACK=1
# LOCALVOX_LIGHT_NO_LOOPBACK=1
# LOCALVOX_LIGHT_LIST_DEVICES=1

# ── Логи tracing (опционально, общий для Rust) ──
# RUST_LOG=info
# RUST_LOG=debug,localvox_light_core=debug
